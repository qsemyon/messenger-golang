// v2
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Universal Run",
            "type": "shell",
            "command": [
                "Clear-Host;",
                "$out = '${workspaceFolder}/.build';",
                "if (!(Test-Path $out)) { New-Item $out -ItemType Directory -Force | Out-Null };",
                "if ('${fileExtname}' -eq '.go') {",
                    "cd '${fileDirname}';",
                    "go run .",
                "}",
                "elseif ('${fileExtname}' -eq '.kt') {",
                    "$d = '${fileDirname}'; $g = $null;",
                    "for ($i=0; $i -lt 8; $i++) {",
                        "if (Test-Path \"$d/build.gradle.kts\") { $g = $d; break };",
                        "$p = Split-Path $d -Parent; if ($p -eq $d) { break }; $d = $p",
                    "};",
                    "if ($g) { cd $g; gradle run }",
                    "else { kotlinc '${file}' -include-runtime -d \"$out/${fileBasenameNoExtension}.jar\"; java -jar \"$out/${fileBasenameNoExtension}.jar\" }",
                "}",
                "elseif ('${fileExtname}' -eq '.py') { python -W ignore '${file}' }",
                "elseif ('${fileExtname}' -eq '.cpp') {",
                    "cd '${fileDirname}';",
                    "if (Test-Path 'CMakeLists.txt') {",
                        "cmake -S . -B build; cmake --build build;",
                        "$app = (Get-ChildItem -Path build -Filter *.exe -Recurse | Where { $_.FullName -notlike '*CMakeFiles*' } | Select -First 1);",
                        "if ($app) { & $app.FullName }",
                    "}",
                    "else { g++ '${file}' -o \"$out/${fileBasenameNoExtension}.exe\"; & \"$out/${fileBasenameNoExtension}.exe\" }",
                "}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": { "kind": "build", "isDefault": true },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "echo": false,
                "clear": true,
                "showReuseMessage": false
            }
        }
    ]
}